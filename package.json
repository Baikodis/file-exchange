{
  "name": "file-exchange",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --watch --env-file=.env src/server.js",
    "pm2": "PM2_HOME=/tmp/pm2-home npx pm2 delete file-exchange 2>/dev/null; PM2_HOME=/tmp/pm2-home npx pm2 start ecosystem.config.cjs && PM2_HOME=/tmp/pm2-home npx pm2 save",
    "pm2:stop": "PM2_HOME=/tmp/pm2-home npx pm2 stop file-exchange",
    "pm2:logs": "PM2_HOME=/tmp/pm2-home npx pm2 logs file-exchange --lines 50 --nostream",
    "restart": "PM2_HOME=/tmp/pm2-home npx pm2 restart file-exchange"
  },
  "dependencies": {
    "express": "^4.21",
    "express-rate-limit": "^7",
    "morgan": "^1",
    "multer": "^1.4.4-lts.1",
    "uuid": "^11"
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
